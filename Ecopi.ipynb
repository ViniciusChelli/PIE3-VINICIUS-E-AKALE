from flask import Flask, jsonify
import random
from datetime import datetime

app = Flask(__name__)

@app.route("/")
def home():
    return """
    <h1>🌱 EcoPi Ituiutaba</h1>
    <h3>API de Monitoramento Ambiental</h3>
    <p>Acesse <a href="/data">/data</a> para visualizar os dados em JSON.</p>
    """

@app.route("/data")
def get_data():

    temperatura = round(random.uniform(18, 38), 1)
    umidade = round(random.uniform(30, 95), 1)
    qualidade_ar = random.randint(0, 150)
    pressao = round(random.uniform(995, 1028), 1)

    if qualidade_ar <= 50:
        status = "Excelente"
    elif qualidade_ar <= 100:
        status = "Boa"
    else:
        status = "Ruim"

    return jsonify({
        "temperatura": temperatura,
        "umidade": umidade,
        "pressao_hPa": pressao,
        "qualidade_ar": qualidade_ar,
        "status_ar": status,
        "local": "IFTM - Campus Ituiutaba",
        "timestamp": datetime.now().strftime("%d/%m/%Y %H:%M:%S")
    })

if __name__ == "__main__":
    app.run(host="0.0.0.0", port=5000, debug=True)
